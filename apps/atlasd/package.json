{
  "name": "@atlas/atlasd",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @atlas/contracts build && pnpm --filter @atlas/storage build && vitest run",
    "dev": "node --watch --experimental-strip-types src/main.ts",
    "start": "node dist/main.js",
    "restore": "node dist/restore.js"
  },
  "dependencies": {
    "@fastify/static": "8.2.0",
    "@atlas/contracts": "workspace:*",
    "@atlas/storage": "workspace:*",
    "fastify": "^5.6.2",
    "zod": "^4.0.0"
  }
}
