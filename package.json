{
  "name": "atlas",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @atlas/atlasd dev",
    "dev:web": "pnpm --filter @atlas/web dev",
    "start": "pnpm --filter @atlas/atlasd start",
    "test": "pnpm -r test && node --test scripts/competition/*.test.mjs",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
